# Public (Vite) — safe for browser bundle
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# If the app is served under a subpath (e.g. GitHub Pages https://user.github.io/repo-name/),
# set base to that path WITH trailing slash, then rebuild:
# VITE_BASE=/repo-name/

# If your host cannot rewrite all routes to index.html (404 on refresh /live-orders), use hash URLs:
# VITE_HASH_ROUTER=true

# Server-side only — NEVER prefix with VITE_. Use for npm run seed:demo only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
